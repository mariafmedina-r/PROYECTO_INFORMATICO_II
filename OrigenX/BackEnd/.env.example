# Conexión Cafetera – Backend variables de entorno (ejemplo)
# Copiar este archivo como .env y completar con los valores reales.

# Firebase Admin SDK – ruta al archivo JSON de credenciales de cuenta de servicio
# Descargar desde Firebase Console > Configuración del proyecto > Cuentas de servicio
FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json

# Firebase Project ID (visible en Firebase Console)
FIREBASE_PROJECT_ID=

# Firebase Storage Bucket (ej: mi-proyecto.appspot.com)
FIREBASE_STORAGE_BUCKET=

# Configuración del servidor
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true

# CORS - orígenes permitidos (separados por coma)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate limiting – intentos fallidos antes de bloqueo temporal (RNF-003.3)
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15
